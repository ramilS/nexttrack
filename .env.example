# APP
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# DATABASE
DATABASE_URL=postgresql://nexttrack:nexttrack_secret@localhost:5432/nexttrack
DATABASE_TEST_URL=postgresql://nexttrack:nexttrack@localhost:5432/nexttrack_test
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
# pg pool timeouts (ms). 0 disables: connection waits forever / idle never closes.
DATABASE_CONNECTION_TIMEOUT_MS=10000
DATABASE_IDLE_TIMEOUT_MS=30000

# AUTH
JWT_ACCESS_SECRET=change_me_in_production_min_32_chars
JWT_REFRESH_SECRET=change_me_in_production_min_32_chars_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# REDIS
VALKEY_URL=valkey://localhost:6379

# MAIL (dev -> mailhog, prod -> SMTP)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_FROM="NextTrack <noreply@nexttrack.local>"
MAIL_USER=
MAIL_PASS=

# MINIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret
MINIO_BUCKET=nexttrack-attachments

# ELASTICSEARCH
ELASTICSEARCH_URL=http://localhost:9200

# ADMIN SEED (optional — if not set, random password is generated)
ADMIN_EMAIL=admin@nexttrack.local
ADMIN_PASSWORD=Password123!

# INVITE
INVITE_TOKEN_TTL_HOURS=72

# SSO / OAuth
# Generate via: openssl rand -hex 32
ENCRYPTION_KEY=change_me_generate_with_openssl_rand_hex_32
SSO_STATE_TTL=600
SSO_FINALIZE_CODE_TTL=30

# MIGRATION (Phase 10)
MIGRATION_API_SECRET=change-me-very-long-random-secret-only-for-migration
MIGRATION_ALLOW_BACKDATED_RECORDS=true

# OBSERVABILITY / TRACING (optional — off by default)
# When OTEL_ENABLED=true, traces export via OTLP/HTTP. Start the jaeger infra
# service and view them at http://localhost:16686 (docker image should be started)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=nexttrack-api
# Base endpoint (OTLP spec) — the SDK appends /v1/traces. Default suits local jaeger.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SAMPLE_RATIO=1
SWAGGER_ENABLED=false

# AUTH (local login) — set false to require SSO only
AUTH_LOCAL_ENABLED=true

# WEBSOCKET
WS_CORS_ORIGINS=http://localhost:3000

# OPS — bearer token gating GET /internal/metrics (Prometheus scrape).
# Unset = metrics open in dev, 404 in prod.
OPS_TOKEN=

# AI-ASSISTED DOCS (off by default; full detail in .claude/rules/ai-docs.md)
AI_DOCS_ENABLED=false
AI_DOCS_PROVIDER=anthropic              # anthropic | openai
ANTHROPIC_API_KEY=
# AI_DOCS_MODEL=                        # required for openai; anthropic defaults to claude-opus-4-8
# AI_DOCS_BASE_URL=                     # openai provider only (local Ollama/LM Studio/vLLM/OpenRouter)

# Other tuning vars all have safe defaults — see apps/api/src/config/*.config.ts
# for the full list (attachments/thumbnails, ELASTICSEARCH_*, search paging,
# OUTBOX_*, NOTIFICATION_* crons, WEBHOOK_*/TELEGRAM_*, APP_REQUEST_TIMEOUT_MS,
# TIME_REPORT_MAX_ROWS, WS_*_TTL_SECONDS).