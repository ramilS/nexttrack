{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "LOG_LEVEL",
    "APP_REQUEST_TIMEOUT_MS",
    "OPS_TOKEN",
    "SWAGGER_ENABLED",
    "OTEL_ENABLED",
    "OTEL_SERVICE_NAME",
    "OTEL_EXPORTER_OTLP_ENDPOINT",
    "OTEL_SAMPLE_RATIO",
    "OUTBOX_POLLER_ENABLED",
    "INTERNAL_API_URL",
    "API_PORT",
    "API_URL",
    "WEB_URL",
    "DATABASE_URL",
    "DATABASE_POOL_MAX",
    "DATABASE_POOL_MIN",
    "REDIS_URL",
    "ENCRYPTION_KEY",
    "JWT_ACCESS_SECRET",
    "JWT_ACCESS_EXPIRES_IN",
    "JWT_REFRESH_SECRET",
    "JWT_REFRESH_EXPIRES_IN",
    "AUTH_LOCAL_ENABLED",
    "INVITE_TOKEN_TTL_HOURS",
    "MINIO_ENDPOINT",
    "MINIO_PORT",
    "MINIO_ACCESS_KEY",
    "MINIO_SECRET_KEY",
    "MINIO_BUCKET",
    "MINIO_USE_SSL",
    "S3_ENDPOINT",
    "S3_PORT",
    "S3_REGION",
    "S3_ACCESS_KEY",
    "S3_SECRET_KEY",
    "S3_BUCKET",
    "S3_USE_SSL",
    "S3_FORCE_PATH_STYLE",
    "PRESIGNED_URL_TTL_SECONDS",
    "ATTACHMENT_MAX_FILE_SIZE_MB",
    "ATTACHMENT_MAX_FILES_PER_UPLOAD",
    "ATTACHMENT_MAX_TOTAL_PER_ISSUE",
    "THUMBNAIL_MAX_WIDTH",
    "THUMBNAIL_MAX_HEIGHT",
    "THUMBNAIL_QUALITY",
    "ELASTICSEARCH_URL",
    "ELASTICSEARCH_INDEX_PREFIX",
    "ELASTICSEARCH_MAX_RETRIES",
    "ELASTICSEARCH_REQUEST_TIMEOUT",
    "INDEXER_BATCH_SIZE",
    "AUTOCOMPLETE_CACHE_TTL",
    "SEARCH_DEFAULT_PAGE_SIZE",
    "SEARCH_MAX_PAGE_SIZE",
    "MAIL_HOST",
    "MAIL_PORT",
    "MAIL_USER",
    "MAIL_PASS",
    "MAIL_FROM",
    "MAIL_SECURE",
    "NOTIFICATION_DIGEST_CRON",
    "NOTIFICATION_DUE_DATE_CHECK_CRON",
    "NOTIFICATION_EMAIL_DELAY_SECONDS",
    "NOTIFICATION_RETENTION_DAYS",
    "NOTIFICATION_UNREAD_COUNT_CACHE_TTL_SECONDS",
    "OUTBOX_BATCH_SIZE",
    "OUTBOX_POLL_INTERVAL_MS",
    "OUTBOX_STALE_TIMEOUT_MS",
    "WEBHOOK_TIMEOUT_MS",
    "WEBHOOK_MAX_RESPONSE_BYTES",
    "WEBHOOK_MAX_CONSECUTIVE_FAILURES",
    "WEBHOOK_ALLOW_PRIVATE_URLS",
    "TELEGRAM_API_BASE_URL",
    "TELEGRAM_TIMEOUT_MS",
    "TELEGRAM_MAX_CONSECUTIVE_FAILURES",
    "SSO_STATE_TTL",
    "SSO_FINALIZE_CODE_TTL",
    "MIGRATION_API_SECRET",
    "MIGRATION_ALLOW_BACKDATED_RECORDS",
    "WS_ADAPTER",
    "WS_CORS_ORIGINS",
    "WS_PRESENCE_TTL_SECONDS",
    "WS_TYPING_TTL_SECONDS"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:unit": {
      "dependsOn": ["^build"]
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false
    }
  }
}
