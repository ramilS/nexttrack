# APP
NODE_ENV=production
API_PORT=3001
WEB_PORT=3000
API_URL=https://your-domain.com
WEB_URL=https://your-domain.com
DOMAIN=your-domain.com

# DATABASE
DATABASE_URL=postgresql://nexttrack:CHANGE_ME@postgres:5432/nexttrack_prod
# pg connection pool (per API process). Tune POOL_MAX against Postgres max_connections.
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
# pg pool timeouts (ms). 0 disables: connection waits forever / idle never closes.
DATABASE_CONNECTION_TIMEOUT_MS=10000
DATABASE_IDLE_TIMEOUT_MS=30000

# AUTH
JWT_ACCESS_SECRET=CHANGE_ME_min_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# AUTH (local login)
AUTH_LOCAL_ENABLED=true

# REDIS
REDIS_URL=valkey://:CHANGE_ME@valkey:6379
REDIS_PASSWORD=CHANGE_ME

# MAIL (production SMTP)
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_SECURE=true
MAIL_FROM="NextTrack <noreply@your-domain.com>"
MAIL_USER=CHANGE_ME
MAIL_PASS=CHANGE_ME

# MINIO / S3
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=nexttrack-attachments

# ELASTICSEARCH
ELASTICSEARCH_URL=http://elasticsearch:9200

# INVITE
INVITE_TOKEN_TTL_HOURS=72

# SSO / OAuth
ENCRYPTION_KEY=CHANGE_ME_64_hex_chars
SSO_STATE_TTL=600
SSO_FINALIZE_CODE_TTL=30

# WEBSOCKET
WS_CORS_ORIGINS=https://your-domain.com

# POSTGRES (for docker-compose)
POSTGRES_DB=nexttrack_prod
POSTGRES_USER=nexttrack
POSTGRES_PASSWORD=CHANGE_ME
