# Default (false): incompatible `engines` in a DEPENDENCY is a warning, not a hard
# error. Required because @prisma/studio-core (transitive via the prisma CLI)
# ships a bogus `engines.pnpm: "8"` that breaks install on our pinned pnpm 9.
# The root project's own `engines.node` is still enforced regardless of this flag.
engine-strict=false