{
  "name": "next_track",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "pnpm --filter api test && pnpm --filter web test",
    "test:unit": "turbo run test:unit",
    "test:integration": "pnpm --filter api test:integration",
    "test:e2e": "pnpm --filter e2e test:e2e"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "turbo": "^2.9.14",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
